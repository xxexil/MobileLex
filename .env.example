# Your PC LAN IP from ipconfig (run `ipconfig` and look for IPv4 Address).
# Works for: Android emulator, iOS simulator, AND physical phone.
# Laravel must be started with: php artisan serve --host=0.0.0.0 --port=8000
EXPO_PUBLIC_API_BASE=http://YOUR_PC_IP:8000/api
EXPO_PUBLIC_SHARED_BACKEND_HOST=YOUR_PC_IP

# Laravel Reverb (for Echo private channels)
EXPO_PUBLIC_REVERB_APP_KEY=
EXPO_PUBLIC_REVERB_HOST=YOUR_PC_IP
EXPO_PUBLIC_REVERB_PORT=8080
EXPO_PUBLIC_REVERB_SCHEME=http

