# Public backend URL. Use this when the API is exposed through Cloudflare Tunnel.
EXPO_PUBLIC_API_BASE=https://openings-aus-connecticut-sherman.trycloudflare.com/api
EXPO_PUBLIC_SHARED_BACKEND_HOST=openings-aus-connecticut-sherman.trycloudflare.com

# Laravel Reverb (for Echo private channels)
EXPO_PUBLIC_REVERB_APP_KEY=lexconnect-key
EXPO_PUBLIC_REVERB_HOST=openings-aus-connecticut-sherman.trycloudflare.com
EXPO_PUBLIC_REVERB_PORT=443
EXPO_PUBLIC_REVERB_SCHEME=https
